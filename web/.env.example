# ─── Supabase (required) ─────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Create tables once in Supabase SQL Editor:
#   web/supabase/schema.sql

# ─── BNB Smart Chain ──────────────────────────────────────
BSC_CHAIN_ID=56
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_EXPLORER=https://bscscan.com
X402_NETWORK=eip155:56

# USDC on BSC (Binance-Peg USDC, 18 decimals).
USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
USDC_DECIMALS=18

BSC_FAUCET_URL=

NEXT_PUBLIC_BSC_CHAIN_ID=56
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org
NEXT_PUBLIC_BSC_EXPLORER=https://bscscan.com
NEXT_PUBLIC_USDC_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
NEXT_PUBLIC_USDC_DECIMALS=18
# ─── Operator (server — only needed for four.meme token launch at Genesis) ─
# Same wallet as creator is fine for solo dev. Fund with BNB.
BSC_OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_KEY
BSC_OPERATOR_ADDRESS=0xYOUR_OPERATOR_ADDRESS
NEXT_PUBLIC_OPERATOR_ADDRESS=0xYOUR_OPERATOR_ADDRESS

# ─── four.meme token launch (Genesis) ───────────────────
FOUR_MEME_TOKEN_MANAGER=0x5c952063c7fc8610FFDB798152D69F0B9550762b
# Optional BNB pre-sale sent with launch tx
FOUR_MEME_LAUNCH_BNB=0
# Token category label (Meme, AI, Defi, Games, Infra, De-Sci, Social, Depin, Charity, Others)
FOUR_MEME_LABEL=AI

# ─── x402 Facilitator (self-hosted — packages/facilitator) ─
FACILITATOR_URL=http://localhost:4020

# ─── Talos Contracts on BNB Smart Chain ──────────────────
NEXT_PUBLIC_TALOS_REGISTRY_CONTRACT=0x...
NEXT_PUBLIC_TALOS_NAME_SERVICE_CONTRACT=0x...

# ─── Per-agent signing keys (provisioned at Genesis) ─────
# TALOS_AGENT_SECRET_<talosId>=0x...

# ─── AI Services ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

SELLER_PUBLIC_URL=http://localhost:4021
