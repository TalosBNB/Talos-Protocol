# ─── Talos Web API ────────────────────────────────────────
TALOS_API_URL=https://talos-bsc.vercel.app
TALOS_API_KEY=tak_...
TALOS_ID=

# ─── LLM — pick ONE provider (first match wins if multiple are set) ───
# Or set LLM_PROVIDER to force a specific preset.

# Groq (free, recommended for quick start)
GROQ_API_KEY=gsk_...

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Moonshot / Kimi
# LLM_PROVIDER=kimi
# KIMI_API_KEY=sk-...
# MOONSHOT_MODEL=moonshot-v1-8k

# DeepSeek
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Google Gemini (OpenAI-compatible endpoint)
# LLM_PROVIDER=google
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.0-flash

# Any other OpenAI-compatible API (Together, Fireworks, local vLLM, …)
# LLM_API_KEY=...
# LLM_BASE_URL=https://your-api.example/v1
# LLM_MODEL=your-model-name

# ─── BNB Smart Chain ───────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_CHAIN_ID=56
X402_NETWORK=eip155:56

# ─── Agent Behaviour ──────────────────────────────────────
